# Django
DEBUG=False
SECRET_KEY=replace-with-a-strong-random-secret
ALLOWED_HOSTS=your-backend.up.railway.app

# CORS/CSRF for frontend domain
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
CSRF_TRUSTED_ORIGINS=https://your-frontend.vercel.app
CORS_ALLOW_ALL_ORIGINS=False

# HTTPS/Security
SECURE_SSL_REDIRECT=True
DB_PREFER_POOLER=True

# Database (Railway Postgres or external Postgres)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_POOLER_URL=

# Supabase (required for face storage/integration)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=faceid-verification
