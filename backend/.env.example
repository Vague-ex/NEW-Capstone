# Django
DEBUG=False
SECRET_KEY=replace-with-a-strong-random-secret
ALLOWED_HOSTS=your-backend.up.railway.app

# CORS/CSRF for frontend domain
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
CSRF_TRUSTED_ORIGINS=https://your-frontend.vercel.app
CORS_ALLOW_ALL_ORIGINS=False

# HTTPS/Security
SECURE_SSL_REDIRECT=True
DB_PREFER_POOLER=True

# Database (Railway Postgres or external Postgres)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_POOLER_URL=

# Supabase (required for face storage/integration)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=faceid-verification

# Email (Gmail SMTP). Use port 587 with TLS. Leave EMAIL_HOST_USER empty
# in local dev to fall back to console backend (logs the email body).
EMAIL_BACKEND=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# Password reset policy
PASSWORD_RESET_CODE_TTL_SECONDS=900
PASSWORD_RESET_RESEND_COOLDOWN_SECONDS=60
PASSWORD_RESET_CODE_LENGTH=12
PASSWORD_RESET_MAX_ATTEMPTS=5

# Login throttle policy (after N fails, cooldown ramps up per the list).
LOGIN_THROTTLE_FAIL_LIMIT=5
LOGIN_THROTTLE_BACKOFF_SECONDS=15,30,60,120,300,600
